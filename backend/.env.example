# Server
PORT=4000
NODE_ENV=development

# PostgreSQL connection string
# Local:  postgres://postgres:postgres@localhost:5432/flowstack_db
# Neon/Supabase/Render: paste the connection string from the dashboard
DATABASE_URL=postgres://postgres:postgres@localhost:5432/flowstack_db

# Set true for hosted DBs that require SSL (Neon, Supabase, Render)
DATABASE_SSL=false

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
